# Единый конец строки в репозитории (LF), автоперевод при checkout на разных ОС.
* text=auto eol=lf

# Явно текстовые файлы.
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
Dockerfile      text eol=lf
.gitignore      text eol=lf
.dockerignore   text eol=lf

# Бинарные файлы — не трогать.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
